{
  "name": "@rulect/vite",
  "description": "Vite plugin integration for Rulect development workflow",
  "version": "0.1.2",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",

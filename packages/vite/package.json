    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "electron": ">=40.0.0",
    "vite": ">=7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rulect/rulect.git",
    "directory": "packages/vite"
  },
  "homepage": "https://github.com/rulect/rulect/tree/main/packages/vite",
